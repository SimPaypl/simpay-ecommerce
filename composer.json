{
    "name": "simpay/ecommerce",
    "description": "PHP SDK for integrating SimPay payments into e-commerce platforms",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "simpay",
        "payments",
        "ecommerce",
        "gateway",
        "php-sdk"
    ],
    "homepage": "https://github.com/SimPaypl/simpay-ecommerce",
    "authors": [
        {
            "name": "SimPay",
            "homepage": "https://simpay.pl"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "SimPay\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimPay\\SDK\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
