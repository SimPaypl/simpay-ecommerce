{
    "name": "simpay/ecommerce",
    "description": "PHP SDK for integrating SimPay payments into e-commerce platforms",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "SimPay",
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "SimPay\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimPay\\SDK\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}

